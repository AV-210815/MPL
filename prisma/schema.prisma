generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Apartment {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  players     Player[]
  matches     Match[]
  users       User[]
}

model User {
  id          Int       @id @default(autoincrement())
  apartmentId Int       @default(1)
  username    String
  password    String
  role        String    @default("user")
  status      String    @default("pending")
  permissions String    @default("[]")
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  @@unique([apartmentId, username])
}

model Player {
  id          Int               @id @default(autoincrement())
  apartmentId Int               @default(1)
  name        String
  photo       String?
  createdAt   DateTime          @default(now())
  apartment   Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  batting     BattingStat[]
  bowling     BowlingStat[]
  memberships MatchTeamMember[]
  potmMatches Match[]           @relation("MatchPOTM")
  @@unique([apartmentId, name])
}

model Match {
  id           Int               @id @default(autoincrement())
  apartmentId  Int               @default(1)
  date         DateTime
  label        String?
  format       String            @default("ODI")
  team1Name    String            @default("Team 1")
  team2Name    String            @default("Team 2")
  battingFirst Int               @default(1)
  season       String?
  result       String?
  potmId       Int?
  createdAt    DateTime          @default(now())
  apartment    Apartment         @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  potm         Player?           @relation("MatchPOTM", fields: [potmId], references: [id], onDelete: SetNull)
  batting      BattingStat[]
  bowling      BowlingStat[]
  members      MatchTeamMember[]
}

model MatchTeamMember {
  id       Int    @id @default(autoincrement())
  matchId  Int
  playerId Int
  team     Int
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model BattingStat {
  id       Int     @id @default(autoincrement())
  playerId Int
  matchId  Int
  innings  Int     @default(1)
  team     Int     @default(1)
  runs     Int
  balls    Int
  fours    Int
  sixes    Int
  notOut    Boolean @default(false)
  dnb       Boolean @default(false)
  dismissal String?
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model BowlingStat {
  id           Int    @id @default(autoincrement())
  playerId     Int
  matchId      Int
  innings      Int    @default(1)
  team         Int    @default(1)
  wickets      Int
  overs        Float
  runsConceded Int
  maidens      Int
  player       Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match        Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
}
